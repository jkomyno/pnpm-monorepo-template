{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^typecheck", "^build", "typecheck"]
    },
    "build:watch": {},
    "check:exports": {
      "dependsOn": ["^build"]
    },
    "app#watch": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "bench": {},
    "bench:watch": {},
    "clean": {
      "cache": false,
      "outputs": ["packages/*/build"]
    }
  }
}
